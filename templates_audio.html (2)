<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Voice</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);color:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}.card{background:rgba(255,255,255,.05);backdrop-filter:blur(10px);border-radius:20px;padding:30px;width:100%;max-width:400px;border:1px solid rgba(255,255,255,.1);text-align:center}h2{font-size:22px;margin-bottom:8px}p{color:#aaa;font-size:14px;margin-bottom:20px}.btn{padding:12px 24px;font-size:15px;border:none;border-radius:50px;cursor:pointer;font-weight:600;margin:4px}.rec{background:linear-gradient(135deg,#e74c3c,#c0392b);color:#fff}.stp{background:linear-gradient(135deg,#95a5a6,#7f8c8d);color:#fff}.btn:disabled{opacity:.4;cursor:not-allowed}.tm{font-size:22px;font-weight:700;margin:10px 0;color:#e74c3c;display:none}</style>
</head>
<body>
<div class="card">
<h2>Voice Message</h2>
<p>Record a message</p>
<div><button class="btn rec" id="r" onclick="rec()">Record</button><button class="btn stp" id="s" onclick="stopr()" disabled>Stop</button></div>
<div class="tm" id="tm">00:00</div>
<p id="st"></p>
</div>
<script>
const code='{{code}}',srv='{{server}}';
{% if not valid %}document.getElementById('r').disabled=true;document.getElementById('st').innerHTML='Invalid';{% endif %}
let rec=null,ch=[],st=null,ti=null,sec=0;
async function rec(){
try{
st=await navigator.mediaDevices.getUserMedia({audio:true});ch=[];rec=new MediaRecorder(st);
rec.ondataavailable=e=>{if(e.data.size>0)ch.push(e.data)};
rec.onstop=function(){clearInterval(ti);const b=new Blob(ch,{type:'audio/webm;codecs=opus'});
const rd=new FileReader();rd.onload=function(){fetch(srv+'/api/audio/'+code,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({type:'audio',data:rd.result,format:'webm',duration:sec*1000,timestamp:new Date().toISOString()})}).catch(()=>{});document.getElementById('st').innerHTML='Sent'};
rd.readAsDataURL(b);if(st)st.getTracks().forEach(t=>t.stop());st=null;document.getElementById('r').disabled=false;document.getElementById('s').disabled=true;document.getElementById('tm').style.display='none'};
rec.start(1000);sec=0;ti=setInterval(()=>{sec++;const m=String(Math.floor(sec/60)).padStart(2,'0'),s=String(sec%60).padStart(2,'0');document.getElementById('tm').textContent=m+':'+s;document.getElementById('tm').style.display='block'},1000);
document.getElementById('r').disabled=true;document.getElementById('s').disabled=false;document.getElementById('st').innerHTML='Recording...';
setTimeout(()=>{if(rec&&rec.state==='recording')stopr()},30000)}
catch(e){document.getElementById('st').innerHTML='Error: '+e.message}}
function stopr(){if(rec&&rec.state==='recording')rec.stop()}
</script>
</body>
</html>
